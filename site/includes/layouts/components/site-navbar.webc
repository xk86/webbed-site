<header class="site-header">
  <a class="site-title" href="/">Cat Olive Webbed Site</a>
  <nav class="site-nav" aria-label="Primary">
    <ul
      @html="this.collections.primaryNav.map((item) => `<li><a href=&quot;${item.url}&quot;${item.url === this.page.url ? ' aria-current=&quot;page&quot;' : ''}>${item.title}</a></li>`).join('')"
    ></ul>
  </nav>
</header>
