<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title @text="title"></title>

    <!-- Theme bootstrap: set desired theme before styles resolve -->
    <script webc:keep>
      (function () {
        var stored;
        try {
          stored = localStorage.getItem('theme');
        } catch (e) {
          stored = null;
        }

        // below bool for silly-default
        // 'theme-srs' ? 'theme-srs' : 'theme-silly';
        var theme = stored === 'theme-silly' ? 'theme-silly' : 'theme-srs';
        document.documentElement.dataset.theme = theme;
      })();
    </script>

    <!-- Theme stylesheets -->
    <link webc:keep rel="stylesheet" href="/pub/themes/base.css">
    <link webc:keep rel="stylesheet" href="/pub/themes/silly.css">
    <link webc:keep rel="stylesheet" href="/pub/themes/srs.css">

    <!-- Theme apply function, defined in head to avoid first-load flicker -->
    <script webc:keep>
      (function () {
        function normalize(theme) {
          //'theme-srs' ? 'theme-srs' : 'theme-silly';
          return theme === 'theme-silly' ? 'theme-silly' : 'theme-srs';
        }

        function apply(theme) {
          var next = normalize(theme);
          document.documentElement.dataset.theme = next;

          try {
            localStorage.setItem('theme', next);
          } catch (e) {
            // Ignore storage errors in restricted contexts.
          }
        }

        apply(document.documentElement.dataset.theme);
        window.__applyTheme = apply;
      })();
    </script>

    <!-- Typefaces -->
    <link webc:keep rel="preconnect" href="https://fonts.googleapis.com">
    <link webc:keep rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link webc:keep href="https://fonts.googleapis.com/css2?family=Alegreya+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
  </head>

  <body>
    <site-navbar></site-navbar>
    <main @html="this.content">
    </main>
    <theme-switcher></theme-switcher>
    <site-footer></site-footer>
  </body>

</html>
